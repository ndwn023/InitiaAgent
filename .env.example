# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── AI Models ────────────────────────────────────────────────────────────────
# Model cascade: Anthropic → Gemini → Claude CLI (no key, stdin pipe)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# local: http://localhost:3000
# production: https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# local: http://localhost:4000
# production (set in Vercel env vars): https://your-backend.up.railway.app
BACKEND_URL=http://localhost:4000

# ─── Frontend (Next.js public vars) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── On-chain Runner (backend executes swaps on behalf of agents) ──────────────
# Private key of the deployer wallet (0x-prefixed) — must match the wallet that
# ran DeployLocal.s.sol and is authorized as runner in AgentExecutor.
INITIA_EVM_RPC=https://jsonrpc-evm-1.anvil.asia-southeast.initia.xyz
