{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "InitiaAgent REST API backend — Express.js + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build --prefix ../packages/shared && tsx watch src/index.ts",
    "build": "npm run build --prefix ../packages/shared && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "npm run build --prefix ../packages/shared && tsx src/scripts/seed-agents.ts",
    "seed:dry": "npm run build --prefix ../packages/shared && tsx src/scripts/seed-agents.ts -- --dry-run",
    "seed:reset": "npm run build --prefix ../packages/shared && tsx src/scripts/seed-agents.ts -- --reset"
  },
  "dependencies": {
    "@initia-agent/shared": "*",
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/genai": "^1.0.0",
    "@neondatabase/serverless": "^0.10.4",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.39",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
