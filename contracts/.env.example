# ─── Deployer ────────────────────────────────────────────────────────────────
# Private key wallet kamu (dengan 0x di depan)
PRIVATE_KEY=0x...

# ─── RPC Endpoints ───────────────────────────────────────────────────────────
# Initia L2 EVM Testnet (evm-1) — MiniEVM rollup
INITIA_TESTNET_RPC=https://jsonrpc-evm-1.anvil.asia-southeast.initia.xyz

# Local (opsional, untuk testing lokal)
INITIA_LOCAL_RPC=http://localhost:8545

# ─── Chain ID ────────────────────────────────────────────────────────────────
# evm-1 L2 testnet EVM chain ID
EVM_CHAIN_ID=2124225178762456

# ─── Token Addresses (evm-1 L2 testnet) ─────────────────────────────────────
# INIT token ERC-20 (native gas token di L2, sudah ada di chain)
INIT_TOKEN_ADDRESS=0x2eE7007DF876084d4C74685e90bB7f4cd7c86e22

# USDC token — deploy MockERC20 dulu via DeployLocal.s.sol, lalu isi alamatnya
USDC_TOKEN_ADDRESS=0x...

# DEX — deploy MockInitiaDEX atau InitiaDEXAdapter, lalu isi alamatnya
DEX_ADDRESS=0x...

# ─── Protocol Config ─────────────────────────────────────────────────────────
# Wallet penerima fee protokol (bisa wallet kamu sendiri untuk testnet)
PROTOCOL_TREASURY=0x...

# Fee & share (basis points)
PROTOCOL_FEE_BPS=200        # 2%
CREATOR_SHARE_BPS=2000      # 20%
EPOCH_DURATION_SECONDS=604800  # 7 hari

# ─── Deployed Addresses (diisi setelah deploy) ───────────────────────────────
REGISTRY_ADDRESS=0x...
EXECUTOR_ADDRESS=0x...
SPLITTER_ADDRESS=0x...
